# Copy to .env.local and fill in. Nothing here is optional in production
# except LLM_MODEL / LLM_PROVIDER overrides.

# Supabase — project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — server-only (Stripe webhook, share-page view counter)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM generation
ANTHROPIC_API_KEY=sk-ant-...
# anthropic (default) | mock — mock runs the whole flow without an API key
LLM_PROVIDER=anthropic
# Defaults to claude-opus-4-8; drop to claude-sonnet-5 to trade quality for cost
# LLM_MODEL=claude-opus-4-8

# Stripe — $5/month subscription
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# The recurring $5/month price (Products → Pro → price ID)
STRIPE_PRICE_ID=price_...

# Absolute URL of this deployment (Stripe redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

